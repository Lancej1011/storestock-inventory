# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/storestock?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Configuration
PORT=3000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google Cloud Vision API Configuration
# Get your API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_PROJECT_ID=inventory-490718

# Path to your service account JSON key file (or set GOOGLE_APPLICATION_CREDENTIALS env var)
GOOGLE_APPLICATION_CREDENTIALS=./inventory-490718-7c843fa5a5d0.json

# Barcode Lookup API (free tier: 100 requests/day)
# Get API key at: https://www.barcodelookup.com/api
BARCODE_LOOKUP_API_KEY=

# EAN Search API (free token registration at https://www.ean-search.org)
EAN_SEARCH_TOKEN=

# SerpAPI (for Walmart/Google Shopping search - free tier available)
# Get API key at: https://serpapi.com
SERP_API_KEY=
